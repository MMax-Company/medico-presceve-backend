# ========================
# 🚀 SERVIDOR
# ========================
PORT=3002
NODE_ENV=production
BASE_URL=https://doctorprescreve.com.br

# ========================
# 🗄️ BANCO DE DADOS (PostgreSQL - Railway)
# ========================
# Adicionado automaticamente pelo Railway ao vincular um PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/railway

# ========================
# 💳 STRIPE (PAGAMENTOS)
# ========================
# Obter em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_ou_sk_live_aqui
STRIPE_WEBHOOK_SECRET=whsec_aqui
CURRENCY=brl
PRODUCT_NAME=Consulta Assincrona
PRODUCT_PRICE=6990

# ========================
# 📱 ULTRAMSG (WHATSAPP)
# ========================
# Obter em: https://ultramsg.com/dashboard
ULTRAMSG_INSTANCE=seu_instance_aqui
ULTRAMSG_TOKEN=seu_token_aqui
WHATSAPP_MODE=test
WHATSAPP_PRIORITY=10

# ========================
# 🔐 CRIPTOGRAFIA (LGPD)
# ========================
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=64_caracteres_hex_aqui
JWT_SECRET=minimo_32_caracteres_seguros

# ========================
# 🔗 MEMED (PRESCRIÇÃO DIGITAL)
# ========================
# Homologação (teste): usar as chaves abaixo
# Produção: solicitar à Memed
MEMED_API_URL=https://integrations.api.memed.com.br/v1
MEMED_API_KEY=sua_api_key_aqui
MEMED_SECRET_KEY=sua_secret_key_aqui

# ========================
# 👨‍⚕️ DADOS DO MÉDICO
# ========================
MEDICO_NOME=SeuNome
MEDICO_SOBRENOME=SeuSobrenome
MEDICO_CPF=00000000000
MEDICO_CONSELHO=CRM
MEDICO_NUMERO=000000
MEDICO_UF=SP
MEDICO_EMAIL=seu@email.com
MEDICO_TELEFONE=11999999999
MEDICO_PASS=admin123

# ========================
# ⚠️ CONFIGURAÇÕES OPCIONAIS
# ========================
RECEITA_VALIDADE_DIAS=180
LOG_LEVEL=info
