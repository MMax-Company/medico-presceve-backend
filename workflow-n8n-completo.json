      "id": "0d3f6395-20d6-4c61-86e6-70bedbccc099",
      "name": "Normalizar Dados1",
      "parameters": {
        "functionCode": "const raw = $input.first().json;\n\n// Se vier encapsulado\nconst dados = raw.body || raw.data || raw;\n\n// Ajustar data (DDMMYYYY → YYYY-MM-DD)\nlet dataNascimento = dados.data_nascimento || \"\";\n\nif (dataNascimento.length === 8) {\n  const dia = dataNascimento.substring(0, 2);\n  const mes = dataNascimento.substring(2, 4);\n  const ano = dataNascimento.substring(4, 8);\n  dataNascimento = `${ano}-${mes}-${dia}`;\n}\n\n// Retorno estruturado\nreturn [\n  {\n    json: {\n      paciente: {\n        nome: dados.nome || \"Paciente\",\n        cpf: dados.cpf || \"\",\n        telefone: String(dados.telefone || \"\").replace(/\\D/g, \"\"),\n        email: dados.email || \"\",\n        data_nascimento: dataNascimento\n      },\n      triagem: {\n        doencas: dados.doencas || [],\n        medicamento: dados.medicamento || \"\",\n        medicamento2: dados.medicamento2 || \"\",\n        tempoUso: dados.tempoUso || \"\",\n        sinaisAlerta: dados.sinaisAlerta || \"Nao\"\n      }\n    }\n  }\n];"
      },
