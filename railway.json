{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyMaxRetries": 5,
    "environment": {
      "DASHBOARD_DATABASE_URL": "${{DASHBOARD_DATABASE_URL}}"
    }
  }
}
